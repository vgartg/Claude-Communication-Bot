# Copy to .env and fill in. The .env file is never committed.

# Telegram bot token from @BotFather
BOT_TOKEN=

# Numeric Telegram user id allowed to use the bot. All other users are ignored.
ALLOWED_USER_ID=

# Command used to launch the agent CLI. It must be installed and authenticated
# on this host. An absolute path is recommended.
AGENT_CMD=agent

# Directory the agent works in by default.
AGENT_WORKDIR=/home/agent/workspace

# How the agent handles tool permissions. Use a non-interactive mode so it can
# run unattended.
AGENT_PERMISSION_MODE=bypassPermissions

# Maximum seconds a single task may run.
AGENT_TIMEOUT=1800

# Show tool activity as it happens (1) or only final replies (0).
SHOW_TOOLS=1

# Storage and agent definitions.
DB_PATH=data/state.db
AGENTS_PATH=agents.yaml
