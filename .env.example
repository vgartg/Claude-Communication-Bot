# --- Required ---

# Get a token from @BotFather in Telegram
CCB_BOT_TOKEN=replace-me

# --- Optional ---

# HTTP host/port for the API (clients connect here)
CCB_HOST=127.0.0.1
CCB_PORT=3000

# Where the user registry (users.json) lives
CCB_DATA_DIR=./data

# Default seconds /api/ask blocks before returning 504. The PreToolUse hook treats 504
# as "user didn't answer in time" and falls back to the terminal UI. 0 = wait forever.
CCB_ASK_TIMEOUT=60

# Optional admin allowlist — comma-separated Telegram user IDs that can run /users.
# Leave empty if you don't need admin commands.
CCB_ADMIN_USER_IDS=
